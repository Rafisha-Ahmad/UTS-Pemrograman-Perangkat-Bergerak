<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Kita paksa menggunakan .Light meskipun di folder night -->
    <style name="Theme.UTS" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Paksa background tetap putih -->
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>