<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="24dp"
    tools:context=".Profile">

    <!-- Judul Halaman -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-black"
        android:text="Profil Mahasiswa"
        android:textColor="@color/navy_primary"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Frame Foto Profil -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfile"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:strokeColor="@color/navy_primary"
        app:strokeWidth="2dp" />

    <!-- Tombol Ganti Foto -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEditPhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="-8dp"
        android:layout_marginBottom="-8dp"
        app:fabSize="mini"
        app:layout_constraintBottom_toBottomOf="@id/ivProfile"
        app:layout_constraintEnd_toEndOf="@id/ivProfile"
        app:srcCompat="@android:drawable/ic_menu_camera"
        app:tint="@color/white"
        app:backgroundTint="@color/navy_primary" />

    <!-- Kartu Detail Data -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/ivProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Field Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lengkap"
                android:textAllCaps="true"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="Masukkan Nama"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="8dp" android:background="#EEEEEE" />

            <!-- Field NIM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIM"
                android:textAllCaps="true"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="Masukkan NIM"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="8dp" android:background="#EEEEEE" />

            <!-- Field Prodi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Studi"
                android:textAllCaps="true"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etProdi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="Masukkan Prodi"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="8dp" android:background="#EEEEEE" />

            <!-- Field Jurusan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jurusan"
                android:textAllCaps="true"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etJurusan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="Masukkan Jurusan"
                android:textColor="@color/black"
                android:textSize="16sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:text="Simpan Profil"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/navy_primary"
        app:layout_constraintBottom_toTopOf="@id/btnBack" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Kembali ke Dashboard"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/gray_text"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>